{
  "states": {
    "introduction": {
		"text":[
		{"text": "<typewriter>Welcome "},
	    {"selector":"@interlocutor"},
		{"text": "<typewriter>, I will show you the ropes to using magic in Fantasy MC. Currently, there are Bewitchment / Besmirchment; Spell Engine Mods (i.e Rouge & Warriors, Wizards, etc...), Archon and Malum. But unfortunately Bewitchment/Besmirchment & Malum needs more time."}
      ],
	  "illustrations": [
        "intro"
      ],
	  "choices": [
        {
          "next": "bewitch",
          "text": "Bewitchment / Besmirchment"
        },
        {
          "next": "spellengine",
          "text": "Spell Engine Mods"
        },
        {
          "next": "archon",
          "text": "Archon"
        },
        {
          "next": "malum",
