        "type": "blabber:command",
        "value": "/execute as @p at @p run ftbquests change_progress @p reset 428B2180EF0B2811"
      }
    },
    "bewitch": {
      "text": "<typewriter>Apologies Adventurer, It is not yet time...",
      "choices": [
        {
          "next": "introduction",
          "text": "Back"
        },
        {
          "next": "end",
          "text": "End"
        }
      ]
    },
    "spellengine": {
      "text": "<typewriter>Spell Engine Mods are mods that adds in <rainb>Spell Books</rainb> and to make these books, you will need a <rainb>Spell Binding Table</rainb>.\nThe table needs to be surrounded with <rainb>24 bookshelves (for spellbooks with 4 spells)</rainb> or <rainb>18 bookshelves (for spellbooks with 3 spells)</rainb>\nNow that you've got the Spell Book, you can equip them as shown.",
      "illustrations": [
        "lookup",
		"spellbook"
      ],
	  "choices": [
        {
          "next": "se2",
          "text": "Weapons"
        },
        {
          "next": "introduction",
          "text": "Back (Introduction)"
        },
        {
          "next": "end",
          "text": "End"
        }
      ]
    },
    "archon": {
      "text": "<typewriter>You may have found these <rainb>tomes</rainb> in chests. They are tomes for the wands/weapons in Archon, right clicking them will mean learning them permanently.",
      "illustrations": [
        "lookup",
		"tome"
      ],
	  "type": "default",
      "choices": [
        {
          "text": "Weapons",
          "next": "ar2"
        },
        {
          "next": "introduction",
          "text": "Back (Introduction)"
        },
        {
          "next": "end",
          "text": "End"
        }
      ]
    },
    "malum": {
	  "text":[
		{"text": "<typewriter>Apologies "},
	    {"selector":"@interlocutor"},
		{"text": "<typewriter>, It is not yet time..."}
      ],
